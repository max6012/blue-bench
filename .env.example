# Blue-Bench local secrets.
# Copy to .env and fill in. .env is gitignored; never commit it.

# ── Frontier-model API runners (optional) ─────────────────────────
# Needed only if you use a cloud-backed profile (e.g., blue_bench_client
# has a path for Anthropic-backed qualify runs).
ANTHROPIC_API_KEY=

# ── Backend service credentials (optional) ───────────────────────
# Wazuh API. If unset, get_agent_alerts uses the ES fallback path.
BLUE_BENCH_WAZUH_USER=
BLUE_BENCH_WAZUH_PASS=

# Elasticsearch. If unset, searches run unauthenticated (lab default).
BLUE_BENCH_ELASTIC_USER=
BLUE_BENCH_ELASTIC_PASS=

# OpenEDR mock. The shipped mock does not require auth.
BLUE_BENCH_OPENEDR_USER=
BLUE_BENCH_OPENEDR_PASS=

# ── Overrides (optional) ─────────────────────────────────────────
# Override default ES URL used by scripts/seed_es.py.
# BLUE_BENCH_ES_URL=http://localhost:9200
