# ── Python runtime / build ──────────────────────────────────────
__pycache__/
*.pyc
*.egg-info/
.venv/
build/
dist/
.pytest_cache/

# ── OS / editor cruft ───────────────────────────────────────────
.DS_Store
.vscode/
.idea/

# ── Secrets / env ───────────────────────────────────────────────
*.env
.env
.env.*
# Allow the template through — it ships without secrets.
!.env.example

# ── Agent / assistant state (personal to contributor) ──────────
.claude/
.plandb.db
CLAUDE.md

# ── Local git hooks (kept out-of-band, never published) ─────────
.githooks/

# ── Internal planning, design specs, board narrative ───────────
# Anything under docs/internal/ is private and must not be published.
docs/internal/
# Demo scripts contain scenario answers / ground truth — keep private.
docs/DEMO_SCRIPT_FRONTEND.md

# ── Run artifacts ──────────────────────────────────────────────
# Scored traces, BLUFs, and run metadata reference scenario-specific
# answers (ground truth) and judging justifications. Never publish.
results/

# ── Data / evidence / forensic samples ─────────────────────────
# Raw telemetry and forensic samples may carry licensing constraints
# (AIT-ADS, Brim, NIST CFReDS) and are not redistributed by this repo.
data/raw/
data/evidence/

# ── Injection bundles (answer keys) ────────────────────────────
# Generated adversary bundles pair injected attack telemetry with
# ground-truth annotations (which events are the signal, the TTP
# attribution, the scoring rubric). Same "never publish ground truth"
# rule as results/ — the harness CODE is committed, the emitted
# bundles are not.
data/bundles/

# ── Model weights ──────────────────────────────────────────────
models/
*.gguf

# ── Local demo run artifacts ───────────────────────────────────
# Screenshots captured during local CLI/MCP demo runs (Chrome DevTools, etc.)
.demo-run/

# ── VM build artifacts (sandbox/vm/) ──────────────────────────
# qcow2 disk images and rebuildable ISOs. Source-of-truth lives in
# autounattend.xml + the build scripts; binaries are env-specific.
sandbox/vm/*.iso
sandbox/vm/*.qcow2
sandbox/vm/*.img
# Per-run timing emissions -- belong in the perf-report, not git.
sandbox/vm/perf-timings*.json
# AWS resource IDs (account-specific, regenerated by aws-provision-net.sh)
sandbox/vm/aws-resources.env
sandbox/vm/aws-resources.env.bak.*
