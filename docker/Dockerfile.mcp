# Blue-Bench MCP server — SSE transport, runs inside the tool-tier compose.
# Build context is the repo root (see compose.tools.yml `mcp.build.context`).
FROM python:3.12-slim AS build
ENV PIP_NO_CACHE_DIR=1 PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONDONTWRITEBYTECODE=1 PYTHONUNBUFFERED=1
WORKDIR /build
COPY pyproject.toml README.md ./
COPY blue_bench_mcp ./blue_bench_mcp
# Build a wheel once, install it in the runtime stage. Keeps runtime slim.
RUN pip install --no-cache-dir build \
 && python -m build --wheel --outdir /build/dist

FROM python:3.12-slim AS runtime
ENV PYTHONDONTWRITEBYTECODE=1 PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 PIP_DISABLE_PIP_VERSION_CHECK=1 \
    BLUE_BENCH_CONFIG=/app/config.yaml
# nmap: MCP container sits on blue-bench-net, can reach 10.10.5.22 directly.
# curl: used by the compose healthcheck.
RUN apt-get update \
 && apt-get install -y --no-install-recommends nmap curl ca-certificates \
 && rm -rf /var/lib/apt/lists/*
RUN useradd --system --create-home --uid 10001 --user-group blue \
 && mkdir -p /app /app/data/evidence \
 && chown -R blue:blue /app
WORKDIR /app
COPY --from=build /build/dist/*.whl /tmp/
RUN pip install --no-cache-dir /tmp/*.whl && rm -f /tmp/*.whl
COPY --chown=blue:blue config.yaml /app/config.yaml
COPY --chown=blue:blue .env.example /app/.env.example
USER blue
EXPOSE 8765
HEALTHCHECK --interval=15s --timeout=5s --retries=6 --start-period=10s \
  CMD curl -fsS http://localhost:8765/health || exit 1
CMD ["python", "-m", "blue_bench_mcp.server", \
     "--config", "/app/config.yaml", \
     "--transport", "sse", \
     "--host", "0.0.0.0", \
     "--port", "8765"]
