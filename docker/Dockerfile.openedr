# OpenEDR mock — FastAPI wrapping the EDR portion of mock_backends.py.
# No real OpenEDR container exists.

FROM python:3.12-slim

RUN pip install --no-cache-dir fastapi uvicorn

COPY docker/mock_backends.py /app/mock_backends.py
COPY docker/openedr_run.py /app/run.py

WORKDIR /app

EXPOSE 9443

CMD ["python", "run.py"]
