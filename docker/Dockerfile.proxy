# Blue-Bench Anthropic proxy — thin HTTPS forwarder to api.anthropic.com.
# Runs inside the LLM-tier compose. Build context is the repo root
# (see compose.llm.yml `anthropic-proxy.build.context`).
#
# This image deliberately does NOT install the full blue-bench wheel —
# the proxy only needs fastapi + uvicorn + httpx + python-dotenv, and
# keeping the image minimal reduces the attack surface of the component
# that holds ANTHROPIC_API_KEY.
FROM python:3.12-slim AS build
ENV PIP_NO_CACHE_DIR=1 PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONDONTWRITEBYTECODE=1 PYTHONUNBUFFERED=1
WORKDIR /wheels
RUN pip install --no-cache-dir \
        "fastapi>=0.110" \
        "uvicorn[standard]>=0.27" \
        "httpx>=0.27" \
        "python-dotenv>=1.0" \
 && pip freeze > /wheels/requirements.txt

FROM python:3.12-slim AS runtime
ENV PYTHONDONTWRITEBYTECODE=1 PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 PIP_DISABLE_PIP_VERSION_CHECK=1
# curl: used by the compose healthcheck against /health.
RUN apt-get update \
 && apt-get install -y --no-install-recommends curl ca-certificates \
 && rm -rf /var/lib/apt/lists/*
RUN useradd --system --create-home --uid 10002 --user-group proxy \
 && mkdir -p /app \
 && chown -R proxy:proxy /app
WORKDIR /app
COPY --from=build /wheels/requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt && rm -f /tmp/requirements.txt
# Only the proxy module — we ship it as a top-level package named
# `blue_bench_mcp` so the existing `python -m blue_bench_mcp.anthropic_proxy`
# entrypoint works unchanged.
COPY --chown=proxy:proxy blue_bench_mcp/__init__.py /app/blue_bench_mcp/__init__.py
COPY --chown=proxy:proxy blue_bench_mcp/anthropic_proxy.py /app/blue_bench_mcp/anthropic_proxy.py
USER proxy
EXPOSE 8766
HEALTHCHECK --interval=15s --timeout=5s --retries=6 --start-period=5s \
  CMD curl -fsS http://localhost:8766/health || exit 1
CMD ["python", "-m", "blue_bench_mcp.anthropic_proxy", \
     "--host", "0.0.0.0", \
     "--port", "8766"]
